# new-api environment variable example
# Copy this file to .env and uncomment only the values you need.
# Boolean values are parsed as true/false unless noted otherwise.

###############################################################################
# Server
###############################################################################

# HTTP listen port. CLI flag --port is used when PORT is empty.
# PORT=3000

# Container/system timezone.
# TZ=Asia/Shanghai

# Gin mode. Any value other than "debug" makes the server run in release mode.
# GIN_MODE=release

# Public frontend base URL used by routes and redirects.
# FRONTEND_BASE_URL=https://your-frontend-url.com

# Override application version shown by the backend.
# VERSION=v0.0.0

# Session and crypto secrets. Do not leave SESSION_SECRET as random_string.
# SESSION_SECRET=replace-with-a-long-random-string
# CRYPTO_SECRET=replace-with-a-long-random-string

# Node role for clustered deployments. Use "slave" to skip master-only work.
# NODE_TYPE=master
# Human-readable node name for audit logs.
# NODE_NAME=node-1

###############################################################################
# Debug, profiling, and observability
###############################################################################

# DEBUG=true
# ENABLE_PPROF=true

# Pyroscope profiling. Leave PYROSCOPE_URL empty to disable.
# PYROSCOPE_URL=http://localhost:4040
# PYROSCOPE_APP_NAME=new-api
# PYROSCOPE_BASIC_AUTH_USER=your-user
# PYROSCOPE_BASIC_AUTH_PASSWORD=your-password
# HOSTNAME=your-hostname
# PYROSCOPE_MUTEX_RATE=5
# PYROSCOPE_BLOCK_RATE=5

# Inject analytics snippets into embedded frontend pages.
# UMAMI_WEBSITE_ID=your-umami-website-id
# UMAMI_SCRIPT_URL=https://analytics.umami.is/script.js
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

###############################################################################
# Database
###############################################################################

# Main database DSN.
# Empty or "local" uses SQLite at SQLITE_PATH.
# MySQL example:
# SQL_DSN=user:password@tcp(127.0.0.1:3306)/new_api?charset=utf8mb4&parseTime=true&loc=Local
# PostgreSQL example:
# SQL_DSN=postgres://user:password@127.0.0.1:5432/new_api?sslmode=disable
# SQL_DSN=local

# Optional separate log database DSN. Empty means reuse SQL_DSN/main database.
# LOG_SQL_DSN=user:password@tcp(127.0.0.1:3306)/new_api_logs?charset=utf8mb4&parseTime=true&loc=Local

# SQLite database path used when SQL_DSN is empty or local.
# SQLITE_PATH=./data/new-api.db

# Skip schema migrations at startup.
# SKIP_DB_MIGRATION=false

# Enable error log persistence.
# ERROR_LOG_ENABLED=false

# SQL connection pool settings.
# SQL_MAX_IDLE_CONNS=100
# SQL_MAX_OPEN_CONNS=1000
# SQL_MAX_LIFETIME=60

###############################################################################
# Redis and cache
###############################################################################

# Redis is disabled when REDIS_CONN_STRING is empty.
# REDIS_CONN_STRING=redis://user:password@localhost:6379/0
# REDIS_POOL_SIZE=10

# In-memory cache. Redis enables memory cache for compatibility.
# MEMORY_CACHE_ENABLED=false
# SYNC_FREQUENCY=60

# Subscription plan cache settings.
# SUBSCRIPTION_PLAN_CACHE_TTL=300
# SUBSCRIPTION_PLAN_INFO_CACHE_TTL=120
# SUBSCRIPTION_PLAN_CACHE_CAP=5000
# SUBSCRIPTION_PLAN_INFO_CACHE_CAP=10000

###############################################################################
# Relay HTTP behavior
###############################################################################

# All relay request timeout in seconds. 0 means no explicit timeout.
# RELAY_TIMEOUT=0
# RELAY_MAX_IDLE_CONNS=500
# RELAY_MAX_IDLE_CONNS_PER_HOST=100

# Relay HTTP 客户端空闲连接超时时间，单位秒，默认跟随 Go 标准库，设置为0表示不限制
# RELAY_IDLE_CONN_TIMEOUT=90
# Streaming idle timeout in seconds.
# STREAMING_TIMEOUT=300

# Request polling interval in seconds for background channel checks.
# POLLING_INTERVAL=0

# Skip TLS certificate verification for outbound HTTP clients.
# TLS_INSECURE_SKIP_VERIFY=false

# File/body safety limits in MB.
# MAX_FILE_DOWNLOAD_MB=64
# MAX_REQUEST_BODY_MB=128
# STREAM_SCANNER_MAX_BUFFER_MB=128

###############################################################################
# Tasks and background jobs
###############################################################################

# Session secret.
# SESSION_SECRET=random_string
# Secure session cookie requires trusted HTTPS entry URLs; separate multiple URLs with commas.
# SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_TRUSTED_URL=https://example.com,https://admin.example.com

# Async task polling and timeout.
# UPDATE_TASK=true
# TASK_QUERY_LIMIT=1000
# TASK_TIMEOUT_MINUTES=1440

# Temporary comma-separated task price patches.
# TASK_PRICE_PATCH=

# Batch updater.
# BATCH_UPDATE_ENABLED=false
# BATCH_UPDATE_INTERVAL=5

# Channel auto-test frequency in minutes. Empty disables env override.
# CHANNEL_TEST_FREQUENCY=

# Legacy channel update frequency in seconds. Empty disables this task.
# CHANNEL_UPDATE_FREQUENCY=

# Upstream model update patrol.
# CHANNEL_UPSTREAM_MODEL_UPDATE_TASK_ENABLED=true
# CHANNEL_UPSTREAM_MODEL_UPDATE_TASK_INTERVAL_MINUTES=30
# CHANNEL_UPSTREAM_MODEL_UPDATE_MIN_CHECK_INTERVAL_SECONDS=300

# Official model/vendor sync upstream and HTTP limits.
# SYNC_UPSTREAM_BASE=https://basellm.github.io/llm-metadata
# SYNC_HTTP_TIMEOUT_SECONDS=15
# SYNC_HTTP_RETRY=3
# SYNC_HTTP_MAX_MB=10

###############################################################################
# Rate limits
###############################################################################

# Global API rate limit.
# GLOBAL_API_RATE_LIMIT_ENABLE=true
# GLOBAL_API_RATE_LIMIT=180
# GLOBAL_API_RATE_LIMIT_DURATION=180

# Global web/dashboard rate limit.
# GLOBAL_WEB_RATE_LIMIT_ENABLE=true
# GLOBAL_WEB_RATE_LIMIT=60
# GLOBAL_WEB_RATE_LIMIT_DURATION=180

# Critical-operation rate limit.
# CRITICAL_RATE_LIMIT_ENABLE=true
# CRITICAL_RATE_LIMIT=20
# CRITICAL_RATE_LIMIT_DURATION=1200

# Authenticated search rate limit.
# SEARCH_RATE_LIMIT_ENABLE=true
# SEARCH_RATE_LIMIT=10
# SEARCH_RATE_LIMIT_DURATION=60

# Notification flood limit.
# NOTIFY_LIMIT_COUNT=2
# NOTIFICATION_LIMIT_DURATION_MINUTE=10

###############################################################################
# Provider and relay feature switches
###############################################################################

# Force streaming usage options for supported channels.
# FORCE_STREAM_OPTION=true

# Note: this key is intentionally mixed-case in code.
# CountToken=true

# Media token accounting.
# GET_MEDIA_TOKEN=true
# GET_MEDIA_TOKEN_NOT_STREAM=false

# Azure default API version.
# AZURE_DEFAULT_API_VERSION=2025-04-01-preview

# Gemini and Cohere safety behavior.
# GEMINI_SAFETY_SETTING=BLOCK_NONE
# COHERE_SAFETY_SETTING=NONE

# Dify workflow/node debug output to clients.
# DIFY_DEBUG=true

# Generate an initial default token.
# GENERATE_DEFAULT_TOKEN=false

# Ali DashScope Claude-compatible model pattern list.
# ALI_ANTHROPIC_MESSAGES_MODELS=qwen,deepseek-v4,kimi,glm,minimax-m

###############################################################################
# Playground image upload
###############################################################################

# Gallery/image-host upload used by /playground image attachments.
# IMAGE_HOST_UPLOAD_URL=https://2bad.lujilujilujilujiluji.com/
# IMAGE_HOST_AUTH_HEADER=Authorization
# IMAGE_HOST_AUTH_VALUE=Bearer cooper
# IMAGE_HOST_FIELD_NAME=file
# IMAGE_HOST_RESPONSE_URL_PATH=url

###############################################################################
# OAuth and provider endpoints
###############################################################################

# LinuxDo OAuth endpoints.
# LINUX_DO_TOKEN_ENDPOINT=https://connect.linux.do/oauth2/token
# LINUX_DO_USER_ENDPOINT=https://connect.linux.do/api/user

###############################################################################
# Redirect and URL validation
###############################################################################

# Trusted redirect domains, comma-separated. Subdomains are allowed.
# Example: example.com,myapp.io allows example.com, sub.example.com, and myapp.io.
# TRUSTED_REDIRECT_DOMAINS=example.com,myapp.io

###############################################################################
# Frontend build/development
###############################################################################

# Frontend API base URL used by web/default and web/classic dev/build tooling.
# VITE_REACT_APP_SERVER_URL=http://localhost:3000

# Build version injected by make/Docker builds.
# VITE_REACT_APP_VERSION=v0.0.0

# Build helper used by the default frontend build in make/Docker.
# DISABLE_ESLINT_PLUGIN=true

###############################################################################
# Electron wrapper
###############################################################################

# Electron data directory. electron/main.js also sets PORT and SQLITE_PATH.
# ELECTRON_DATA_DIR=

###############################################################################
# Test-only variables
###############################################################################

# Used by integration tests.
# TEST_MYSQL_DSN=user:password@tcp(127.0.0.1:3306)/new_api_test?charset=utf8mb4&parseTime=true&loc=Local
# TEST_POSTGRES_DSN=postgres://user:password@127.0.0.1:5432/new_api_test?sslmode=disable

# Used by make reset-setup when SQLITE_PATH is not set.
# DEV_SQLITE_PATH=one-api.db
